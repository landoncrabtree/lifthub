{
    auto_https off
}

:80 {

    root * /srv/frontend
    encode gzip

    handle /api/* {
        reverse_proxy backend:3001
    }

    @static path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff2
    header @static Cache-Control "public, max-age=31536000, immutable"

    handle {
        try_files {path} /index.html
        file_server
    }
}
